# Email (SMTP) - Gmail or Office 365 / Outlook
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=your_email@example.com
EMAIL_TO=recipient@example.com

# Optional: multiple recipients (comma-separated)
# EMAIL_TO=recipient@example.com,another@example.com

# Paths
OUTPUT_DIR=output
DB_PATH=policy_monitor.db
LOG_DIR=logs

# Behaviour
MAX_ITEMS_PER_RUN=500
TOP_DEVELOPMENTS=8
WATCHLIST_ITEMS=5
TLDR_BULLETS=8
MAX_ITEM_AGE_HOURS=36
MIN_RELEVANCE_SCORE=25
WEEKLY_DAY_OF_WEEK=6
SOURCE_PROFILE=fuel_policy

# Request settings
REQUEST_TIMEOUT=8
REQUEST_DELAY=0.2
USER_AGENT=PolicyMonitor/1.0 (research@example.com)

# Optional: twitterapi.io account monitoring
# Add TWITTERAPI_IO_KEY as a GitHub Actions secret, not a repository variable.
TWITTERAPI_IO_KEY=your_twitterapi_io_key

# Influential accounts to monitor, comma-separated without @.
# Example: AlboMP,ChrisBowenMP,METI_JPN,MOF_Singapore
X_ACCOUNT_HANDLES=

# Local keyword filter applied to selected accounts.
X_KEYWORDS=diesel,petrol,gasoline,gasoil,fuel,refinery,refineries,fuel security,Strait of Hormuz,Hormuz,fuel reserve,petroleum reserve,fuel shortage
X_MAX_RESULTS=25
X_LOOKBACK_HOURS=36
X_INCLUDE_RETWEETS=false
X_SECTION_ITEMS=8
