# ── Email (SMTP) — Office 365 / Outlook ─────────────────────────────────────
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=ahmed.jawad@mandalapartners.com
SMTP_PASSWORD=your_outlook_password      # Your Outlook / M365 password
EMAIL_FROM=ahmed.jawad@mandalapartners.com
EMAIL_TO=ahmed.jawad@mandalapartners.com

# ── Optional: multiple recipients (comma-separated) ─────────────────────────
# EMAIL_TO=ahmed.jawad@mandalapartners.com,another@example.com

# ── Paths (defaults work fine; override if needed) ───────────────────────────
OUTPUT_DIR=output
DB_PATH=policy_monitor.db
LOG_DIR=logs

# ── Behaviour ────────────────────────────────────────────────────────────────
MAX_ITEMS_PER_RUN=200          # hard cap on items fetched per run
TOP_DEVELOPMENTS=5             # items in Section 2
WATCHLIST_ITEMS=3              # items in Section 3
TLDR_BULLETS=6                 # items in Section 1
MAX_ITEM_AGE_HOURS=24          # only include items from the last 24 hours (0 = no filter)
WEEKLY_DAY_OF_WEEK=6           # day to send weekly outlook: 0=Mon … 6=Sun (default: Sunday)

# ── Request settings ─────────────────────────────────────────────────────────
REQUEST_TIMEOUT=15
REQUEST_DELAY=1.5              # seconds between HTTP requests (be polite)
USER_AGENT=PolicyMonitor/1.0 (research@mandalapartners.com)
