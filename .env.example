# Email (SMTP) - Gmail or Office 365 / Outlook
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=your_email@example.com
EMAIL_TO=recipient@example.com

# Optional: multiple recipients (comma-separated)
# EMAIL_TO=recipient@example.com,another@example.com

# Paths
OUTPUT_DIR=output
DB_PATH=policy_monitor.db
LOG_DIR=logs

# Behaviour
MAX_ITEMS_PER_RUN=500
TOP_DEVELOPMENTS=8
WATCHLIST_ITEMS=5
TLDR_BULLETS=8
MAX_ITEM_AGE_HOURS=36
MIN_RELEVANCE_SCORE=25
WEEKLY_DAY_OF_WEEK=6
SOURCE_PROFILE=fuel_policy

# Request settings
REQUEST_TIMEOUT=8
REQUEST_DELAY=0.2
USER_AGENT=PolicyMonitor/1.0 (research@example.com)

# Optional: twitterapi.io account monitoring
# Add TWITTERAPI_IO_KEY as a GitHub Actions secret, not a repository variable.
TWITTERAPI_IO_KEY=your_twitterapi_io_key

# Influential accounts to monitor, comma-separated without @.
# Leave blank to use the built-in default watchlist.
X_ACCOUNT_HANDLES=AlboMP,JEChalmers,SenatorWong,MadeleineMHKing,ayrestim,senator_farrell,PatConroy1,murraywatt,CatherineKingMP,AngusTaylorMP,ACCCgovau,dfat,mineralscouncil,Nationalfarmers,au_energy_prod,Johnkehoe23,angelamacd,NickToscano1,JavierBlas,IEA,FatihBirol,Opecsecretariat,Hellenicship,realDonaldTrump,CENTCOM,araghchi,Meti_nippon,JOGMEC_JP,takaichi_sanae,NikkeiAsia,AnwarIbrahim,Lawrencewongst,MTI_sg,MFAsg,channelnewsasia,Bangkokpostnews,MFAThai,Reuters,abcpolitics,financialreview,AJEnglish,FTenergy,WSJenergy,australian
X_PERSON_ACCOUNT_HANDLES=AlboMP,JEChalmers,SenatorWong,MadeleineMHKing,ayrestim,senator_farrell,PatConroy1,murraywatt,CatherineKingMP,AngusTaylorMP,Johnkehoe23,angelamacd,NickToscano1,JavierBlas,FatihBirol,realDonaldTrump,araghchi,takaichi_sanae,AnwarIbrahim,Lawrencewongst
X_MEDIA_ACCOUNT_HANDLES=Hellenicship,NikkeiAsia,channelnewsasia,Bangkokpostnews,Reuters,abcpolitics,financialreview,AJEnglish,FTenergy,WSJenergy,australian

# Local keyword filter applied to selected accounts.
X_KEYWORDS=diesel,petrol,gasoline,gasoil,fuel,refinery,refineries,fuel security,Strait of Hormuz,Hormuz,fuel reserve,petroleum reserve,fuel shortage
X_MAX_RESULTS=25
X_MAX_MATCHES_PER_ACCOUNT=500
X_MAX_SCAN_PAGES_PER_ACCOUNT=100
X_LOOKBACK_HOURS=24
X_INCLUDE_RETWEETS=false
X_SECTION_ITEMS=8
